# Required for stdio mode: Bitpanda API key (https://web.bitpanda.com/apikey)
# In HTTP mode, each user sends their key as a Bearer token instead.
BITPANDA_API_KEY=your-api-key-here

# Optional: Override base URL
# BITPANDA_BASE_URL=https://api.bitpanda.com

# Optional: Request timeout in seconds (default: 30)
# REQUEST_TIMEOUT_S=30

# --- Remote hosting (HTTP mode) ---
# Uncomment these to run as a remote HTTP server instead of stdio.
# FASTMCP_TRANSPORT=streamable-http
# FASTMCP_HOST=0.0.0.0
# FASTMCP_PORT=8000
# FASTMCP_STATELESS_HTTP=true
